<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/splash_gradient"
    android:orientation="vertical">

    <!-- Sun -->
    <ImageView
        android:id="@+id/sun"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:src="@drawable/ic_sun1"
        android:visibility="invisible" />


    <!-- Cloud 1 (Big) -->
    <ImageView
        android:id="@+id/cloud1"
        android:layout_width="120dp"
        android:layout_height="80dp"
        android:layout_marginTop="150dp"
        android:layout_marginLeft="20dp"
        android:src="@drawable/ic_cloud" />

    <!-- Cloud 2 (Medium) -->
    <ImageView
        android:id="@+id/cloud2"
        android:layout_width="100dp"
        android:layout_height="60dp"
        android:layout_marginTop="200dp"
        android:layout_marginRight="30dp"
        android:layout_alignParentEnd="true"
        android:src="@drawable/ic_cloud" />

    <!-- Cloud 3 (Small) -->
    <ImageView
        android:id="@+id/cloud3"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:layout_marginTop="100dp"
        android:layout_marginLeft="50dp"
        android:src="@drawable/ic_cloud" />

    <!-- Cloud 4 (Medium) -->
    <ImageView
        android:id="@+id/cloud4"
        android:layout_width="90dp"
        android:layout_height="55dp"
        android:layout_marginTop="250dp"
        android:layout_marginRight="50dp"
        android:layout_alignParentEnd="true"
        android:src="@drawable/ic_cloud" />

    <!-- App Name -->
    <TextView
        android:id="@+id/app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="SkyCast"
        android:fontFamily="@font/castoro"
        android:textColor="@color/white"
        android:textSize="42sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:shadowColor="#3A3C42"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="3" />


    <com.airbnb.lottie.LottieAnimationView
        android:layout_centerInParent="true"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:lottie_rawRes="@raw/animation_birds1"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />

    <!-- Weather Icon -->


    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimationView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_alignParentBottom="true"
        app:lottie_rawRes="@raw/sky_animation"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />


    <TextView
        android:layout_width="90dp"
        android:layout_height="wrap_content"

        android:layout_alignParentBottom="true"
        android:layout_centerInParent="true"
        android:paddingBottom="20dp"
        android:fontFamily="@font/brygada_1918"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="Created By Moon"
        android:textColor="#B3AEAE"
        android:textSize="14sp" />


</RelativeLayout>